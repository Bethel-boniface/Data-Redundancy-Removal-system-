# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dedup_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Feature Flags
ENABLE_HASHING=true
HASH_ALGORITHM=sha256
SIMILARITY_THRESHOLD=0.85

# Cloud/Storage (if needed)
CLOUD_PROVIDER=aws
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
