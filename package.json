{
  "name": "data-deduplication-system",
  "version": "1.0.0",
  "description": "System for identifying and classifying redundant and false positive data with validation and deduplication",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "deduplication",
    "validation",
    "data-quality",
    "redundancy-detection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "uuid": "^9.0.0",
    "joi": "^17.11.0",
    "pino": "^8.15.0",
    "pino-http": "^8.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
