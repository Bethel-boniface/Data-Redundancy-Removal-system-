{
  "name": "data-deduplication-system",
  "version": "1.0.0",
  "description": "System for identifying and classifying redundant and false positive data with validation and deduplication",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage",
    "migrate": "node db/migrate.js",
    "seed": "node db/seed.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "deduplication",
    "validation",
    "data-quality",
    "redundancy-detection"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "dotenv": "^17.4.2",
    "cors": "^2.8.6",
    "helmet": "^8.2.0",
    "uuid": "^14.0.1",
    "joi": "^18.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
